;; nft framework — Phase 5: cross-chain relocation (policy passport) suite.
;;
;; REPL TIER: the repl carries the defpact yield across an env-chain-data
;; chain-id switch, so this suite proves the passport mechanics — send-side
;; validation, per-policy state serialization, receive-side re-binding,
;; provenance (wrong-chain resume rejected), and the cross-chain anti-forgery
;; property. What one repl CANNOT prove (one shared database): SPV
;; verification and the first-arrival materialization of the token row on a
;; chain that has never seen it — those are DEVNET evidence, exercised by the
;; Phase-5 devnet campaign on real chains.
;;
;; Proves:
;;   * relocation moves the balance + supply out of the source chain view and
;;     back in on the target, with the policies' passports re-bound;
;;   * sale-only tokens relocate only owner->owner (no free transfer via two
;;     chain hops); a 1/1 relocates whole;
;;   * a resume on the WRONG chain is rejected (yield provenance);
;;   * the id cannot be forged on the target chain: create-token re-derivation
;;     uses the local chain-id, so the same details produce a DIFFERENT id and
;;     the original id fails the protocol check for everyone;
;;   * hooks are unreachable outside the ledger path.
;;
;; Run: pact contracts/nft/test/xchain.repl

;; --- coin (unused, stack parity) ----------------------------------------------
(begin-tx "coin")
(load "../../registry/kip/fungible-v2/fungible-v2.pact")
(load "../../registry/kip/fungible-xchain-v1/fungible-xchain-v1.pact")
(load "../../registry/core/coin/coin-v6.pact")
(create-table coin.coin-table)
(commit-tx)

;; --- the nft framework ----------------------------------------------------------
(begin-tx "deploy nft framework")
(env-chain-data { "chain-id": "0" })
(env-data
  { "g": { "keys": ["9999999999999999999999999999999999999999999999999999999999999999"], "pred": "keys-all" }
  , "ns": "nft", "admin-ks": "nft.admin" })
(env-keys ["9999999999999999999999999999999999999999999999999999999999999999"])
(define-namespace "nft" (read-keyset 'g) (read-keyset 'g))
(namespace "nft")
(define-keyset "nft.admin" (read-keyset 'g))
(load "../interfaces/account-protocols.pact")
(load "../interfaces/token-policy.pact")
(load "../interfaces/poly-fungible.pact")
(load "../interfaces/ledger-iface.pact")
(load "../interfaces/sale.pact")
(load "../core/util.pact")
(load "../core/policy-manager.pact")
(create-table nft.policy-manager.ledgers)
(create-table nft.policy-manager.quotes)
(create-table nft.policy-manager.sale-contracts)
(load "../core/ledger.pact")
(create-table nft.ledger.ledger-table)
(create-table nft.ledger.tokens)
(nft.policy-manager.init nft.ledger)
(load "../policies/royalty-policy.pact")
(create-table nft.royalty-policy.royalties)
(load "../policies/non-fungible-policy.pact")
(create-table nft.non-fungible-policy.minted-table)
(load "../policies/guarded-uri-policy.pact")
(create-table nft.guarded-uri-policy.uri-guards)
(load "../policies/guard-policy.pact")
(create-table nft.guard-policy.op-guards)
(commit-tx)

;; --- token X: royalty (transferable) + 1/1 + guarded uri, created on chain 0 ---
(begin-tx "create + mint token X on chain 0")
(env-chain-data { "chain-id": "0" })
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
  , "royalty_spec": { "creator": "k:1111111111111111111111111111111111111111111111111111111111111111"
                    , "creator-guard": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
                    , "bps": 1000, "sale-only": false }
  , "uri_guard": { "keys": ["cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"], "pred": "keys-all" } })
(env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111", "caps": [] } ])
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://voyager", 'precision: 0
            , 'policies: [nft.royalty-policy nft.non-fungible-policy nft.guarded-uri-policy] }
            (read-keyset 'alice))))
  (nft.ledger.create-token id 0 "ipfs://voyager"
    [nft.royalty-policy nft.non-fungible-policy nft.guarded-uri-policy] (read-keyset 'alice))
  (nft.ledger.mint id "k:1111111111111111111111111111111111111111111111111111111111111111"
    (read-keyset 'alice) 1.0))
(commit-tx)

;; ===========================================================================
;; SEND-SIDE VALIDATION
;; ===========================================================================
(begin-tx "invalid relocations reject")
(env-chain-data { "chain-id": "0" })
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" } })
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://voyager", 'precision: 0
            , 'policies: [nft.royalty-policy nft.non-fungible-policy nft.guarded-uri-policy] }
            (read-keyset 'alice))))
  (env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111"
              , "caps": [ (nft.ledger.XTRANSFER id
                            "k:1111111111111111111111111111111111111111111111111111111111111111"
                            "k:1111111111111111111111111111111111111111111111111111111111111111" "0" 1.0) ] } ])
  (expect-failure "the same chain is not a relocation target" "cannot relocate to the same chain"
    (nft.ledger.transfer-crosschain id
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      (read-keyset 'alice) "0" 1.0))
  ;; a stranger cannot relocate alice's token (DEBIT = her account guard)
  (env-sigs [ { "key": "3333333333333333333333333333333333333333333333333333333333333333"
              , "caps": [ (nft.ledger.XTRANSFER id
                            "k:1111111111111111111111111111111111111111111111111111111111111111"
                            "k:3333333333333333333333333333333333333333333333333333333333333333" "1" 1.0) ] } ])
  (expect-failure "a stranger cannot relocate someone's token" "Keyset failure"
    (nft.ledger.transfer-crosschain id
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      "k:3333333333333333333333333333333333333333333333333333333333333333"
      (read-keyset 'alice) "1" 1.0)))
(rollback-tx)

;; ===========================================================================
;; RELOCATION 0 -> 1 (alice relocates her own token)
;; ===========================================================================
(begin-tx "step 0 on chain 0: policies emit passports, balance + supply leave")
(env-chain-data { "chain-id": "0" })
(env-hash (hash "xc-1"))
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" } })
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://voyager", 'precision: 0
            , 'policies: [nft.royalty-policy nft.non-fungible-policy nft.guarded-uri-policy] }
            (read-keyset 'alice))))
  (env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111"
              , "caps": [ (nft.ledger.XTRANSFER id
                            "k:1111111111111111111111111111111111111111111111111111111111111111"
                            "k:1111111111111111111111111111111111111111111111111111111111111111" "1" 1.0) ] } ])
  (nft.ledger.transfer-crosschain id
    "k:1111111111111111111111111111111111111111111111111111111111111111"
    "k:1111111111111111111111111111111111111111111111111111111111111111"
    (read-keyset 'alice) "1" 1.0)
  (expect "the token left the source chain balance" 0.0
    (nft.ledger.get-balance id "k:1111111111111111111111111111111111111111111111111111111111111111"))
  (expect "the source-chain supply is 0" 0.0 (nft.ledger.total-supply id)))
(commit-tx)

(begin-tx "a resume on the WRONG chain is rejected (yield provenance)")
(env-chain-data { "chain-id": "2" })
(expect-failure "chain 2 cannot claim a yield addressed to chain 1" "Yield provenance"
  (continue-pact 1 false (hash "xc-1")))
(rollback-tx)

(begin-tx "step 1 on chain 1: passports re-bind, balance + supply arrive")
(env-chain-data { "chain-id": "1" })
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" } })
(continue-pact 1 false (hash "xc-1"))
;; the id was DERIVED on chain 0 — recompute it under that chain-id
(env-chain-data { "chain-id": "0" })
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://voyager", 'precision: 0
            , 'policies: [nft.royalty-policy nft.non-fungible-policy nft.guarded-uri-policy] }
            (read-keyset 'alice))))
  (env-chain-data { "chain-id": "1" })
  (expect "alice holds the token on chain 1" 1.0
    (nft.ledger.get-balance id "k:1111111111111111111111111111111111111111111111111111111111111111"))
  (expect "the supply arrived" 1.0 (nft.ledger.total-supply id))
  (expect "the royalty passport is bound (rate intact)" 1000
    (at 'bps (nft.royalty-policy.get-royalty id)))
  (expect "the 1/1 marker is bound" true (nft.non-fungible-policy.is-minted id)))
(commit-tx)

;; the token is fully ALIVE on chain 1: its policies keep working
(begin-tx "post-relocation life: a free transfer works under the traveled rules")
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
  , "bob": { "keys": ["2222222222222222222222222222222222222222222222222222222222222222"], "pred": "keys-all" } })
;; the id was DERIVED on chain 0 — recompute it under that chain-id
(env-chain-data { "chain-id": "0" })
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://voyager", 'precision: 0
            , 'policies: [nft.royalty-policy nft.non-fungible-policy nft.guarded-uri-policy] }
            (read-keyset 'alice))))
  (env-chain-data { "chain-id": "1" })
  (env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111"
              , "caps": [ (nft.ledger.TRANSFER id
                            "k:1111111111111111111111111111111111111111111111111111111111111111"
                            "k:2222222222222222222222222222222222222222222222222222222222222222" 1.0) ] } ])
  (nft.ledger.transfer-create id
    "k:1111111111111111111111111111111111111111111111111111111111111111"
    "k:2222222222222222222222222222222222222222222222222222222222222222"
    (read-keyset 'bob) 1.0)
  (expect "bob holds the relocated token" 1.0
    (nft.ledger.get-balance id "k:2222222222222222222222222222222222222222222222222222222222222222")))
(commit-tx)

;; ===========================================================================
;; SALE-ONLY tokens relocate only owner -> owner
;; ===========================================================================
(begin-tx "sale-only: cross-chain ownership change is a rejected free transfer")
(env-chain-data { "chain-id": "0" })
(env-hash (hash "xc-so"))
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
  , "bob": { "keys": ["2222222222222222222222222222222222222222222222222222222222222222"], "pred": "keys-all" }
  , "royalty_spec": { "creator": "k:1111111111111111111111111111111111111111111111111111111111111111"
                    , "creator-guard": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
                    , "bps": 500, "sale-only": true } })
(env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111", "caps": [] } ])
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://locked", 'precision: 0, 'policies: [nft.royalty-policy] }
            (read-keyset 'alice))))
  (nft.ledger.create-token id 0 "ipfs://locked" [nft.royalty-policy] (read-keyset 'alice))
  (nft.ledger.mint id "k:1111111111111111111111111111111111111111111111111111111111111111"
    (read-keyset 'alice) 1.0)
  (env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111"
              , "caps": [ (nft.ledger.XTRANSFER id
                            "k:1111111111111111111111111111111111111111111111111111111111111111"
                            "k:2222222222222222222222222222222222222222222222222222222222222222" "1" 1.0) ] } ])
  (expect-failure "sale-only blocks a cross-chain ownership change"
    "sale-only token: cross-chain relocation only to the same owner"
    (nft.ledger.transfer-crosschain id
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      "k:2222222222222222222222222222222222222222222222222222222222222222"
      (read-keyset 'bob) "1" 1.0))
  ;; ... but the owner may relocate it to themselves
  (env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111"
              , "caps": [ (nft.ledger.XTRANSFER id
                            "k:1111111111111111111111111111111111111111111111111111111111111111"
                            "k:1111111111111111111111111111111111111111111111111111111111111111" "1" 1.0) ] } ])
  (expect "the owner relocates a sale-only token to themselves" true
    (nft.ledger.transfer-crosschain id
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      (read-keyset 'alice) "1" 1.0)))
(commit-tx)

;; ===========================================================================
;; ANTI-FORGERY ACROSS CHAINS — the relocated id cannot be minted anywhere
;; ===========================================================================
(begin-tx "the id cannot be re-created on the target chain")
(env-chain-data { "chain-id": "1" })
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
  , "mallory": { "keys": ["3333333333333333333333333333333333333333333333333333333333333333"], "pred": "keys-all" } })
(env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111", "caps": [] }
          , { "key": "3333333333333333333333333333333333333333333333333333333333333333", "caps": [] } ])
;; recompute the chain-0 id by hand: derivation on chain 1 gives a DIFFERENT id
(env-chain-data { "chain-id": "0" })
(let ((id0 (nft.ledger.create-token-id
             { 'uri: "ipfs://voyager", 'precision: 0
             , 'policies: [nft.royalty-policy nft.non-fungible-policy nft.guarded-uri-policy] }
             (read-keyset 'alice))))
  (env-chain-data { "chain-id": "1" })
  (let ((id1 (nft.ledger.create-token-id
               { 'uri: "ipfs://voyager", 'precision: 0
               , 'policies: [nft.royalty-policy nft.non-fungible-policy nft.guarded-uri-policy] }
               (read-keyset 'alice))))
    (expect "the same details derive DIFFERENT ids on different chains" false (= id0 id1)))
  ;; the chain-0 id fails the protocol re-derivation for EVERYONE on chain 1
  (expect-failure "even the creator cannot re-create the relocated id here"
    "token protocol violation"
    (nft.ledger.create-token id0 0 "ipfs://voyager"
      [nft.royalty-policy nft.non-fungible-policy nft.guarded-uri-policy] (read-keyset 'alice))))
(rollback-tx)

;; --- hooks unreachable outside the ledger path -----------------------------------
(begin-tx "direct calls are rejected")
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" } })
(let ((fake:object{nft.token-policy.token-info}
        { 'id: "n:fake", 'supply: 1.0, 'precision: 0, 'uri: "ipfs://fake"
        , 'policies: [nft.royalty-policy] }))
  (expect-failure "manager xchain-send is not directly callable" "not granted"
    (nft.policy-manager.enforce-xchain-send fake "k:a" "k:b" (read-keyset 'alice) "1" 1.0))
  (expect-failure "manager xchain-receive is not directly callable" "not granted"
    (nft.policy-manager.enforce-xchain-receive fake "k:b" (read-keyset 'alice) 1.0
      [{ "policy": "nft.royalty-policy", "state": { "bps": 0 } }]))
  (expect-failure "a policy's xchain hook is not directly callable" "not granted"
    (nft.royalty-policy.enforce-xchain-send fake "k:a" "k:b" (read-keyset 'alice) "1" 1.0)))
(rollback-tx)

;; ===========================================================================
;; TRANSFER-GUARD PARITY — an x-chain ownership change is a free transfer in
;; two hops: guard-policy's transfer-guard must authorize it exactly as it
;; authorizes a same-chain transfer; a self-relocation changes no ownership
;; and stays ungated
;; ===========================================================================
(begin-tx "create + mint token G (guard-policy, restricted transfer) on chain 0")
(env-chain-data { "chain-id": "0" })
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
  , "operation_guards":
      { "mint-guard":     { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
      , "burn-guard":     { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
      , "sale-guard":     { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
      , "transfer-guard": { "keys": ["dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"], "pred": "keys-all" } } })
(env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111", "caps": [] } ])
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://guarded", 'precision: 0, 'policies: [nft.guard-policy] }
            (read-keyset 'alice))))
  (nft.ledger.create-token id 0 "ipfs://guarded" [nft.guard-policy] (read-keyset 'alice))
  (nft.ledger.mint id "k:1111111111111111111111111111111111111111111111111111111111111111"
    (read-keyset 'alice) 1.0))
(commit-tx)

(begin-tx "an x-chain ownership change without the transfer-guard rejects")
(env-chain-data { "chain-id": "0" })
(env-hash (hash "xc-guard-1"))
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
  , "bob":   { "keys": ["2222222222222222222222222222222222222222222222222222222222222222"], "pred": "keys-all" } })
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://guarded", 'precision: 0, 'policies: [nft.guard-policy] }
            (read-keyset 'alice))))
  ;; alice (the OWNER) authorizes the debit, but the transfer-guard (dddd…)
  ;; does not sign — the two-hop free transfer must fail like a same-chain one
  (env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111"
              , "caps": [ (nft.ledger.XTRANSFER id
                            "k:1111111111111111111111111111111111111111111111111111111111111111"
                            "k:2222222222222222222222222222222222222222222222222222222222222222" "1" 1.0) ] } ])
  (expect-failure "the transfer-guard gates an x-chain ownership change" "Keyset failure"
    (nft.ledger.transfer-crosschain id
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      "k:2222222222222222222222222222222222222222222222222222222222222222"
      (read-keyset 'bob) "1" 1.0)))
(rollback-tx)

(begin-tx "with the transfer-guard the x-chain ownership change proceeds")
(env-chain-data { "chain-id": "0" })
(env-hash (hash "xc-guard-2"))
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" }
  , "bob":   { "keys": ["2222222222222222222222222222222222222222222222222222222222222222"], "pred": "keys-all" } })
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://guarded", 'precision: 0, 'policies: [nft.guard-policy] }
            (read-keyset 'alice))))
  (env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111"
              , "caps": [ (nft.ledger.XTRANSFER id
                            "k:1111111111111111111111111111111111111111111111111111111111111111"
                            "k:2222222222222222222222222222222222222222222222222222222222222222" "1" 1.0) ] }
            , { "key": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd", "caps": [] } ])
  (expect "the transfer-guard authorizes the x-chain ownership change (step 0)" true
    (nft.ledger.transfer-crosschain id
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      "k:2222222222222222222222222222222222222222222222222222222222222222"
      (read-keyset 'bob) "1" 1.0)))
(rollback-tx)

(begin-tx "a self-relocation needs no transfer-guard (no ownership change)")
(env-chain-data { "chain-id": "0" })
(env-hash (hash "xc-guard-3"))
(env-data
  { "alice": { "keys": ["1111111111111111111111111111111111111111111111111111111111111111"], "pred": "keys-all" } })
(let ((id (nft.ledger.create-token-id
            { 'uri: "ipfs://guarded", 'precision: 0, 'policies: [nft.guard-policy] }
            (read-keyset 'alice))))
  (env-sigs [ { "key": "1111111111111111111111111111111111111111111111111111111111111111"
              , "caps": [ (nft.ledger.XTRANSFER id
                            "k:1111111111111111111111111111111111111111111111111111111111111111"
                            "k:1111111111111111111111111111111111111111111111111111111111111111" "1" 1.0) ] } ])
  (expect "the owner relocates to themselves without the transfer-guard (step 0)" true
    (nft.ledger.transfer-crosschain id
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      "k:1111111111111111111111111111111111111111111111111111111111111111"
      (read-keyset 'alice) "1" 1.0)))
(rollback-tx)

(print "")
(print "=== NFT FRAMEWORK PHASE 5 — CROSS-CHAIN PASSPORT: ALL GREEN (REPL TIER) ===")
(print "  relocation moves balance+supply out and back in; passports re-bind")
(print "  (royalty rate + 1/1 marker + uri guard); wrong-chain resume rejected;")
(print "  sale-only relocates owner->owner only; the id cannot be re-created on")
(print "  another chain (different derivation, protocol check fails for all).")
(print "  SPV + first-arrival materialization = devnet evidence (Phase 5 campaign).")
