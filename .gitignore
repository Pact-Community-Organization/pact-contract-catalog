# Pact REPL session history
# Created automatically by the pact CLI when running .repl files interactively.
# Should never be committed — contains editor/REPL state, not catalog content.
.pc-history
**/.pc-history

# Raw module dump output
# Generated by scripts/describe_tokens.sh — exploratory scratch data, not curated catalog content.
# Curated on-chain source lives in contracts/ecosystem/**/*.pact
module_dump/
module_dump/tmp/

# System and editor files
.DS_Store
Thumbs.db
*.log

# IDE/editor directories
.idea/
.vscode/

# Python bytecode (validation scripts)
__pycache__/
*.pyc

# Test coverage artifacts
# Generated by the REPL coverage tooling; regenerated on demand, never curated
# catalog content. Coverage thresholds are enforced in CI, not by committed files.
coverage/
**/coverage/
*.lcov
lcov.info
**/lcov.info
